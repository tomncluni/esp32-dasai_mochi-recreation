const int BUTTON_PIN = 1;

const int BLANK_INDEX = 12;
const int NUM_REAL_ANIMS = 12;

const unsigned long FRAME_TIME = 100;
const unsigned long DEBOUNCE_TIME = 30;

const unsigned long LONG_PRESS_TIME = 800; // ms threshold

unsigned long lastFrameTime = 0;
unsigned long lastDebounceTime = 0;
unsigned long lastAutoTrigger = 0;

int frame = 0;
int animIndex = BLANK_INDEX;

bool playingBlank = true;

// MODE
bool useButtonMode = true;

// button tracking
bool buttonState = HIGH;
bool lastButtonReading = HIGH;
unsigned long buttonPressTime = 0;

// --------------------------------------------------
int getRandomAnim() {
  static int lastAnim = -1;
  int next;

  do {
    next = random(NUM_REAL_ANIMS);
  } while (next == lastAnim);

  lastAnim = next;
  return next;
}

// --------------------------------------------------
void setup() {
  u8g2.begin();

  pinMode(BUTTON_PIN, INPUT_PULLUP);

  randomSeed(esp_random());
}

// --------------------------------------------------
void loop() {

  // ================= BUTTON HANDLING =================
  bool reading = digitalRead(BUTTON_PIN);

  if (reading != lastButtonReading) {
    lastDebounceTime = millis();
  }

  if ((millis() - lastDebounceTime) > DEBOUNCE_TIME) {

    if (reading != buttonState) {
      buttonState = reading;

      // BUTTON PRESSED
      if (buttonState == LOW) {
        buttonPressTime = millis();
      }

      // BUTTON RELEASED
      if (buttonState == HIGH) {

        unsigned long pressDuration = millis() - buttonPressTime;

        // ================= LONG PRESS =================
        if (pressDuration >= LONG_PRESS_TIME) {
          useButtonMode = !useButtonMode;

          // optional: reset to idle when switching modes
          frame = 0;
          animIndex = BLANK_INDEX;
          playingBlank = true;
        }

        // ================= SHORT PRESS =================
        else {

          if (useButtonMode && playingBlank) {
            animIndex = getRandomAnim();
            frame = 0;
            playingBlank = false;
          }
        }
      }
    }
  }

  lastButtonReading = reading;

  // ================= AUTO MODE =================
  if (!useButtonMode) {

    if (playingBlank && millis() - lastAutoTrigger > 10000) {
      lastAutoTrigger = millis();

      animIndex = getRandomAnim();
      frame = 0;
      playingBlank = false;
    }
  }

  // ================= FRAME TIMING =================
  if (millis() - lastFrameTime < FRAME_TIME) {
    return;
  }

  lastFrameTime = millis();

  frame++;

  // ================= ANIMATION STATE =================
  if (!playingBlank) {

    if (frame >= animLengths[animIndex]) {
      frame = 0;
      animIndex = BLANK_INDEX;
      playingBlank = true;
    }

  } else {

    if (frame >= animLengths[BLANK_INDEX]) {
      frame = 0;
    }
  }

  // ================= DRAW =================
  u8g2.clearBuffer();

  u8g2.drawXBMP(
    0, 0, 128, 64,
    animations[animIndex][frame]
  );

  u8g2.sendBuffer();
}